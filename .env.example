# ───────────────────────────────────────────────
# CRM 대시보드 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요:
#   cp .env.example .env
# .env 는 .gitignore 로 제외되어 커밋되지 않습니다.
# ───────────────────────────────────────────────

# ── 서버 / 데이터 경로 (Docker Manager 배포용) ──
# 서버 포트. Docker Manager가 주입하면 그 값을 사용, 없으면 10020.
PORT=10020
# 런타임 데이터 파일(crm-campaign-data.json 등) 저장 경로.
# Docker 배포 시 볼륨 경로(/app/data)로 설정하면 재배포 후에도 데이터가 유지됨.
DATA_DIR=/app/data

# ── SQL Server (bar_shop1, Azure SQL) 접속정보 ──
DB_SERVER=your-db-host
DB_PORT=1433
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ── 대시보드 로그인 (Basic Auth) ──
CRM_AUTH_USER=barunson
CRM_AUTH_PASS=change-me

# ── Bitly URL 단축 (URL 관리 기능) ──
BITLY_TOKEN=

# ── Claude API (AI 분석 기능, 선택) ──
ANTHROPIC_API_KEY=
